<div class="toast" id="toast"></div>

<script>
const TOAST = document.getElementById('toast');
let toastTimer = null;
function showToast(t) {
  TOAST.textContent = t;
  TOAST.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => TOAST.classList.remove('show'), 2000);
}
function copyPrompt(mode) {
  const url = 'https://github.com/SagaSmithAI/SagaSmith-dnd-skills';
  const lang = document.documentElement.getAttribute('data-lang') || 'zh';
  if (mode === 'full') {
    const txt = lang === 'zh'
      ? `帮我装 ${url}，用完整版`
      : `Install ${url}, full version`;
    navigator.clipboard.writeText(txt).then(() => showToast(lang === 'zh' ? '✅ 已复制！告诉 Agent：' + txt : '✅ Copied! Tell your agent: ' + txt));
  } else {
    const txt = lang === 'zh'
      ? `帮我装 ${url}，用轻量版`
      : `Install ${url}, standalone version`;
    navigator.clipboard.writeText(txt).then(() => showToast(lang === 'zh' ? '✅ 已复制！告诉 Agent：' + txt : '✅ Copied! Tell your agent: ' + txt));
  }
}

// Lang toggle
document.querySelectorAll('[data-lang-btn]').forEach(btn => {
  btn.addEventListener('click', () => {
    const lang = btn.getAttribute('data-lang-btn');
    document.documentElement.setAttribute('data-lang', lang);
    document.querySelectorAll('[data-lang-btn]').forEach(b => b.classList.toggle('active', b === btn));
  });
});
// Quick-start tab switch
document.querySelectorAll('[data-tab]').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('[data-tab]').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('p-' + tab.getAttribute('data-tab')).classList.add('active');
  });
});
// UI preview tab switch
document.querySelectorAll('[data-ui]').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('[data-ui]').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.ui-panel').forEach(p => p.style.display = 'none');
    tab.classList.add('active');
    document.getElementById('ui-' + tab.getAttribute('data-ui')).style.display = 'block';
  });
});
</script>
