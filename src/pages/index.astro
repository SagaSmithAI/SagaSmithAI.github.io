---
// ── Data ──────────────────────────────────────────────────────
const ecosystems = [
  { emoji: '🏗️', name: 'sagasmith-core', zh: '通用引擎 — DB、文档、RAG、FTS5、快照、插件系统', en: 'System-neutral engine — DB, docs, RAG, FTS5, snapshots, plugin system', tag: 'Core' },
  { emoji: '⚔️', name: 'sagasmith-dnd', zh: 'D&D 5e 2014/2024 运行时 + CLI + HTTP API serve', en: 'D&D 5e 2014/2024 runtime + CLI + HTTP API serve', tag: 'System', tag2: 'serve' },
  { emoji: '🕯️', name: 'sagasmith-coc', zh: 'CoC 7e 运行时 + CLI，三种解析模式', en: 'CoC 7e runtime + CLI, three parsing modes', tag: 'System' },
  { emoji: '🖥️', name: 'sagasmith-dnd-ui', zh: 'D&D 管理面板 — Astro + React', en: 'D&D admin dashboard — Astro + React', tag: 'UI' },
  { emoji: '🖥️', name: 'sagasmith-coc-ui', zh: 'CoC 守秘人面板 — Astro + React', en: 'CoC Keeper dashboard — Astro + React', tag: 'UI' },
  { emoji: '🎲', name: 'SagaSmith-agent', zh: '完整 AI DM 运行时（NanoBot）', en: 'Full AI DM runtime on NanoBot', tag: 'Runtime' },
  { emoji: '📦', name: 'SagaSmith-dnd-skills', zh: 'D&D Agent Skills — full + standalone', en: 'D&D agent skills — full + standalone', tag: 'Skills' },
  { emoji: '📦', name: 'SagaSmith-coc-skills', zh: 'CoC Agent Skills — full + standalone', en: 'CoC agent skills — full + standalone', tag: 'Skills' },
  { emoji: '✍️', name: 'SagaSmith-module-gen-skills', zh: '冒险模组生成器，25 种范式', en: 'Adventure module generator, 25 paradigms', tag: 'Skills' },
];

const features = [
  { icon: '🏛️', zh: '战役管理', en: 'Campaigns', zhd: 'SQLite/PostgreSQL 双后端、Alembic 迁移、DAG 存档树、分支读档、战役记忆修订追踪', end: 'SQLite/PostgreSQL, Alembic migrations, DAG save tree, branch-aware restore, revisioned memory' },
  { icon: '🎲', zh: '规则检索', en: 'Rule Search', zhd: '三层混合搜索：精确 + FTS5 BM25 全文索引 + 可选 ChromaDB 语义搜索。中文查询自动英文扩展', end: '3-layer hybrid: exact + FTS5 BM25 + optional ChromaDB. CN query auto-expands EN terms' },
  { icon: '📖', zh: '模组导入', en: 'Module Import', zhd: 'PDF/Markdown 解析、结构感知分块、场景索引。D&D 中英双语合并，CoC solo 节点识别', end: 'PDF/Markdown parsing, structure-aware chunking, scene indexes. CN/EN merge, CoC solo detection' },
  { icon: '⚔️', zh: '战斗引擎', en: 'Combat', zhd: 'd20 真随机、先攻/命中/暴击、回合追踪。CoC d100/对抗、SAN/疯狂、追逐', end: 'True d20 initiative/hit/crit, turn tracking. CoC d100/opposed, SAN/insanity, chases' },
  { icon: '🖥️', zh: '管理面板', en: 'Dashboard', zhd: 'Astro + React 本地管理后台。serve 暴露 JSON API，前端直连', end: 'Astro + React admin dashboard. HTTP API via serve command.' },
  { icon: '🪶', zh: '零依赖轻量', en: 'Standalone', zhd: '纯 Python 标准库便携版，数据存 ~/.sagasmith/。无 pip 环境可用', end: 'Python stdlib-only portable mode. Data at ~/.sagasmith/. Works without pip.' },
];

const repos = [
  { emoji: '🏗️', name: 'sagasmith-core', url: 'https://github.com/SagaSmithAI/Sagasmith-core', zh: '通用引擎', en: 'General engine', stack: 'Python · SQLAlchemy · FTS5 · ChromaDB' },
  { emoji: '⚔️', name: 'sagasmith-dnd', url: 'https://github.com/SagaSmithAI/Sagasmith-dnd', zh: 'D&D 运行时 + CLI', en: 'D&D runtime + CLI', stack: 'Python · FastAPI · D&D 5e' },
  { emoji: '🕯️', name: 'sagasmith-coc', url: 'https://github.com/SagaSmithAI/Sagasmith-coc', zh: 'CoC 运行时 + CLI', en: 'CoC runtime + CLI', stack: 'Python · CoC 7e' },
  { emoji: '🖥️', name: 'sagasmith-dnd-ui', url: 'https://github.com/SagaSmithAI/sagasmith-dnd-ui', zh: 'D&D 管理面板', en: 'D&D admin UI', stack: 'Astro · React · TypeScript' },
  { emoji: '🖥️', name: 'sagasmith-coc-ui', url: 'https://github.com/SagaSmithAI/sagasmith-coc-ui', zh: 'CoC 守秘人面板', en: 'CoC Keeper UI', stack: 'Astro · React · TypeScript' },
  { emoji: '🎲', name: 'SagaSmith-agent', url: 'https://github.com/SagaSmithAI/SagaSmith-agent', zh: 'AI DM 运行时', en: 'AI DM runtime', stack: 'NanoBot · Python · 16+ Channels' },
  { emoji: '📦', name: 'SagaSmith-dnd-skills', url: 'https://github.com/SagaSmithAI/SagaSmith-dnd-skills', zh: 'D&D Skill 定义', en: 'D&D skill defs', stack: 'SKILL.md · full + standalone' },
  { emoji: '📦', name: 'SagaSmith-coc-skills', url: 'https://github.com/SagaSmithAI/SagaSmith-coc-skills', zh: 'CoC Skill 定义', en: 'CoC skill defs', stack: 'SKILL.md · full + standalone' },
  { emoji: '✍️', name: 'SagaSmith-module-gen-skills', url: 'https://github.com/SagaSmithAI/SagaSmith-module-gen-skills', zh: '模组生成器', en: 'Module generator', stack: 'SKILL.md · 25 paradigms' },
];
---
<!DOCTYPE html>
<html lang="zh-CN" data-lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SagaSmith — AI 桌游地下城</title>
  <meta name="description" content="SagaSmith — 自主 AI 地下城主运行时，支持 D&D 5e 和 Call of Cthulhu 7e。SQLite 持久化、FTS5 全文检索、ChromaDB 可选。跨平台 Agent Skills，零依赖轻量版可用。">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans SC",sans-serif;font-size:16px;line-height:1.7;color:#1a1a2e;background:#f8f9fa}
    [data-lang="zh"] .en-only{display:none}
    [data-lang="en"] .zh-only{display:none}

    /* ── Animation ── */
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    @keyframes glow{0%,100%{box-shadow:0 0 20px rgba(240,192,64,.15)}50%{box-shadow:0 0 40px rgba(240,192,64,.25)}}
    .anim{animation:fadeUp .6s ease-out both}
    .anim-1{animation-delay:.1s}.anim-2{animation-delay:.2s}.anim-3{animation-delay:.3s}
    .anim-4{animation-delay:.4s}.anim-5{animation-delay:.5s}.anim-6{animation-delay:.6s}

    /* ── Layout ── */
    .lang-toggle{position:fixed;top:14px;right:20px;z-index:100;display:flex;gap:4px;background:rgba(26,26,46,.9);backdrop-filter:blur(10px);padding:4px;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.3)}
    .lang-btn{border:none;background:transparent;padding:6px 14px;border-radius:7px;cursor:pointer;font-size:13px;color:rgba(255,255,255,.5);transition:all .2s}
    .lang-btn.active{background:rgba(240,192,64,.15);color:#f0c040}
    .container{max-width:1040px;margin:0 auto;padding:0 24px}
    section{padding:80px 0}
    h2{font-size:1.8rem;font-weight:700;text-align:center}
    .sec-sub{text-align:center;color:#6b7280;margin-bottom:48px;font-size:1.05rem;max-width:600px;margin-left:auto;margin-right:auto}

    /* ── Hero ── */
    .hero{background:linear-gradient(160deg,#0f0f1a 0%,#1a1a2e 40%,#1e1e3a 70%,#0f0f1a 100%);color:#fff;text-align:center;padding:120px 24px 100px;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 40%,rgba(240,192,64,.06) 0%,transparent 70%),radial-gradient(ellipse 40% 50% at 70% 60%,rgba(83,144,217,.06) 0%,transparent 70%);pointer-events:none}
    .hero-logo{width:160px;height:160px;margin-bottom:28px;border-radius:32px;display:inline-block;position:relative;animation:fadeIn 1s ease-out,glow 4s ease-in-out infinite;box-shadow:0 0 30px rgba(240,192,64,.1)}
    .hero-logo img{width:100%;height:100%;border-radius:32px;object-fit:cover;display:block}
    .hero h1{font-size:clamp(2.2rem,5vw,3.5rem);font-weight:800;letter-spacing:-.03em;margin-bottom:12px;position:relative;animation:fadeUp .6s ease-out}
    .hero p{font-size:clamp(1rem,2vw,1.15rem);color:rgba(255,255,255,.6);max-width:560px;margin:0 auto;position:relative;animation:fadeUp .6s .1s ease-out both}
    .hero-sub{font-style:italic;color:rgba(240,192,64,.5);font-size:.95rem;margin:20px auto 40px;position:relative;animation:fadeUp .6s .2s ease-out both}
    .btn-group{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative;animation:fadeUp .6s .3s ease-out both}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;transition:all .25s cubic-bezier(.4,0,.2,1)}
    .btn-primary{background:linear-gradient(135deg,#f0c040,#e0a800);color:#1a1a2e}.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(240,192,64,.3)}
    .btn-outline{background:rgba(255,255,255,.06);color:rgba(255,255,255,.9);border:1px solid rgba(255,255,255,.12)}.btn-outline:hover{background:rgba(255,255,255,.12);transform:translateY(-3px)}

    /* ── Section background alternation ── */
    .sec-light{background:#fff}
    .sec-alt{background:#f8f9fa}

    /* ── Feature cards ── */
    .grid-3{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
    .f-card{background:#fff;border-radius:14px;padding:28px;box-shadow:0 1px 4px rgba(0,0,0,.04);border:1px solid #eef0f2;transition:all .25s cubic-bezier(.4,0,.2,1)}
    .f-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08);border-color:#e0e2e5}
    .f-card .icon{font-size:2rem;display:block;margin-bottom:12px}
    .f-card h3{font-size:1.05rem;margin-bottom:6px;font-weight:600}
    .f-card p{color:#6b7280;font-size:.88rem;line-height:1.65}

    /* ── Ecosystem cards ── */
    .eco-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
    .eco-card{background:#fff;border-radius:14px;padding:22px;box-shadow:0 1px 4px rgba(0,0,0,.04);border:1px solid #eef0f2;display:flex;align-items:flex-start;gap:14px;transition:all .25s cubic-bezier(.4,0,.2,1)}
    .eco-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
    .eco-card .emoji{font-size:1.5rem;flex-shrink:0;margin-top:2px}
    .eco-card-body{flex:1;min-width:0}
    .eco-card-body h3{font-size:.95rem;font-weight:600;margin-bottom:3px}
    .eco-card-body p{color:#6b7280;font-size:.82rem;line-height:1.5}
    .ecoTags{margin-top:8px;display:flex;gap:4px;flex-wrap:wrap}
    .ecotag{display:inline-block;font-size:.7rem;padding:2px 10px;border-radius:20px;background:#f3f4f6;color:#6b7280}
    .ecotag.tag-serve{background:#dbeafe;color:#1e40af}
    .ecotag.tag-ui{background:#ede9fe;color:#5b21b6}

    /* ── Variants ── */
    .dual{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px}
    .vc{border-radius:16px;padding:32px;border:1.5px solid #eef0f2;background:#fff;transition:all .25s ease}
    .vc:hover{box-shadow:0 8px 24px rgba(0,0,0,.06)}
    .vc-feat{border-color:#f0c040;background:linear-gradient(135deg,#fffdf5,#fff);position:relative}
    .vc-feat::before{content:'RECOMMENDED';position:absolute;top:-10px;right:24px;background:#f0c040;color:#1a1a2e;font-size:.68rem;font-weight:700;padding:3px 14px;border-radius:20px;letter-spacing:.04em}
    .vc h3{font-size:1.1rem;font-weight:700;margin-bottom:4px}
    .vc .deps{font-size:.8rem;color:#9ca3af;margin-bottom:14px}
    .vc ul{list-style:none}
    .vc li{padding:5px 0;font-size:.88rem;color:#4b5563}
    .vc li::before{content:'✓ ';color:#f0c040;font-weight:700}
    .vc li.no::before{content:'✗ ';color:#9ca3af}

    /* ── Code blocks ── */
    .tabs{display:flex;gap:0;border-bottom:2px solid #eef0f2;margin:32px 0 0;justify-content:center}
    .tab{background:transparent;border:none;padding:10px 24px;cursor:pointer;font-size:.9rem;font-weight:500;color:#9ca3af;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
    .tab.active{color:#1a1a2e;border-bottom-color:#f0c040;font-weight:600}
    .panel{display:none}.panel.active{display:block}
    .code{background:#0f0f1a;border-radius:14px;padding:24px 28px;color:#e2e8f0;font-family:"SF Mono","Fira Code",monospace;font-size:.82rem;line-height:2;overflow-x:auto;margin:20px 0}
    .code .c{color:#6b7280}.code .p{color:#72efdd}.code .s{color:#f0c040}.code .k{color:#e94560}

    /* ── UI Preview ── */
    .demo-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:28px}
    .demo-card{border-radius:12px;overflow:hidden;border:1px solid #eef0f2;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.04);transition:all .25s cubic-bezier(.4,0,.2,1)}
    .demo-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08)}
    .demo-head{display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid #f3f4f6;font-weight:600;font-size:.82rem}
    .demo-body{padding:14px 16px}
    .demo-stat-row{display:flex;gap:8px;margin-bottom:12px}
    .demo-stat{flex:1;text-align:center;padding:10px 6px;border-radius:8px;border:1px solid #f3f4f6;background:#fafafa}
    .demo-stat-n{font-size:1.3rem;font-weight:700}
    .demo-stat-l{font-size:.62rem;color:#9ca3af;margin-top:1px}
    .demo-item{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;border-radius:6px;font-size:.82rem}
    .demo-item:hover{background:#f9fafb}
    .demo-b{padding:1px 8px;border-radius:10px;font-size:.62rem;font-weight:500}
    .demo-prog{height:4px;border-radius:2px;background:#f3f4f6;overflow:hidden;margin:6px 0}
    .demo-prog-f{height:100%;border-radius:2px;transition:width .6s ease}
    .demo-t{display:inline-block;font-size:.6rem;padding:1px 6px;border-radius:3px;background:#f9fafb;color:#9ca3af;margin:1px}
    /* D&D theme: gold accent */
    .dnd .demo-head{border-left:3px solid #f0c040}
    .dnd .demo-stat-n{color:#1a1a2e}
    .dnd .demo-prog-f{background:linear-gradient(90deg,#f0c040,#e0a800)}
    .dnd .demo-b{background:#fef3c7;color:#92400e}
    /* CoC theme: purple accent */
    .coc .demo-head{border-left:3px solid #7c3aed}
    .coc .demo-stat-n{color:#7c3aed}
    .coc .demo-prog-f{background:linear-gradient(90deg,#7c3aed,#6d28d9)}
    .coc .demo-b{background:#ede9fe;color:#5b21b6}

    table{width:100%;border-collapse:collapse;font-size:.85rem}
    th{text-align:left;padding:12px 14px;color:#6b7280;font-weight:600;border-bottom:2px solid #eef0f2}
    td{padding:12px 14px;border-bottom:1px solid #f3f4f6}
    td a{color:#1a1a2e;text-decoration:none;font-weight:500}
    td a:hover{color:#f0c040}
    td .stack{color:#9ca3af;font-size:.78rem}

    .arch{background:#0f0f1a;color:#e2e8f0;border-radius:16px;padding:36px;font-family:"SF Mono","Fira Code",monospace;font-size:.8rem;line-height:1.9;overflow-x:auto;white-space:pre;margin-top:32px}
    .hl{color:#f0c040}.hl2{color:#5390d9}.hl3{color:#72efdd}.hl-d{color:#6b7280}

    /* ── Arch layers ── */
    .arch{display:flex;flex-direction:column;gap:8px;margin-top:32px}
    .arch-layer{border-radius:14px;padding:18px 22px;position:relative}
    .arch-layer h3{font-size:.88rem;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:8px}
    .arch-layer p{font-size:.8rem;line-height:1.6}
    .arch-layer .tag{font-size:.7rem;padding:1px 8px;border-radius:4px;display:inline-block;margin:2px}
    .arch-arrow{text-align:center;font-size:.7rem;color:#9ca3af;padding:2px 0;position:relative}
    .arch-arrow::before{content:'▲';font-size:.6rem}
    .arch-layer.l1{background:linear-gradient(135deg,#eef2ff,#e0e7ff);border:1px solid #c7d2fe}
    .arch-layer.l1 .tag{background:#c7d2fe;color:#3730a3}
    .arch-layer.l2{background:linear-gradient(135deg,#fef9e7,#fef3c7);border:1px solid #fde68a}
    .arch-layer.l2 .tag{background:#fde68a;color:#92400e}
    .arch-layer.l3{background:linear-gradient(135deg,#f0fdf4,#d1fae5);border:1px solid #a7f3d0}
    .arch-layer.l3 .tag{background:#a7f3d0;color:#065f46}
    .arch-layer.l4{background:linear-gradient(135deg,#f5f3ff,#ede9fe);border:1px solid #ddd6fe}
    .arch-layer.l4 .tag{background:#ddd6fe;color:#5b21b6}
    .arch-layer.l5{background:linear-gradient(135deg,#f8f9fa,#e9ecef);border:1px solid #dee2e6}
    .arch-layer.l5 .tag{background:#dee2e6;color:#495057}
    .arch-layer .chip{display:inline-block;font-size:.7rem;padding:2px 10px;border-radius:20px;margin:1px 2px}

    /* ── Copy button ── */
    .copy-btn{display:inline-flex;align-items:center;gap:6px;margin-top:16px;padding:8px 18px;border-radius:8px;font-size:.8rem;font-weight:500;border:1.5px solid #eef0f2;background:#fff;cursor:pointer;transition:all .2s;color:#4b5563}
    .copy-btn:hover{background:#f9fafb;border-color:#d1d5db}
    .copy-btn.copied{background:#d1fae5;border-color:#6ee7b7;color:#065f46}
    .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a2e;color:#fff;padding:10px 24px;border-radius:10px;font-size:.85rem;z-index:200;opacity:0;transition:opacity .3s;pointer-events:none}
    .toast.show{opacity:1}

    /* ── Copy button ── */
    .copy-btn{display:inline-flex;align-items:center;gap:6px;margin-top:16px;padding:8px 18px;border-radius:8px;font-size:.8rem;font-weight:500;border:1.5px solid #eef0f2;background:#fff;cursor:pointer;transition:all .2s;color:#4b5563}
    .copy-btn:hover{background:#f9fafb;border-color:#d1d5db}
    .copy-btn.copied{background:#d1fae5;border-color:#6ee7b7;color:#065f46}

    footer{background:#0f0f1a;color:rgba(255,255,255,.4);text-align:center;padding:48px 24px;font-size:.82rem}
    footer a{color:rgba(255,255,255,.6);text-decoration:none}
    footer a:hover{color:#f0c040}
    .flinks{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:16px}

    @media(max-width:768px){
      .dual,.eco-grid,.demo-grid{grid-template-columns:1fr}
      .hero{padding:80px 20px 60px}
      .hero-logo{width:120px;height:120px}
      section{padding:48px 0}
    }
    
  </style>
</head>
<body>
<div class="lang-toggle">
  <button class="lang-btn active" data-lang-btn="zh">中文</button>
  <button class="lang-btn" data-lang-btn="en">EN</button>
</div>

<!-- Hero -->
<section class="hero">
  <div class="hero-logo"><img src="/logo.png" alt="SagaSmith"></div>
  <h1>SagaSmith</h1>
  <p class="zh-only">让 AI 成为你的地下城主 — 规则引擎、战役管理、模组导入，一个 CLI 全搞定。</p>
  <p class="en-only">Turn AI into your Dungeon Master — rule engine, campaign management, module import, all in one CLI.</p>
  <p class="hero-sub zh-only">SQLite 持久化 · FTS5 全文检索 · ChromaDB 可选 · 零依赖轻量版</p>
  <p class="hero-sub en-only">SQLite persistent · FTS5 full-text · ChromaDB optional · Zero-dep standalone</p>
  <div class="btn-group">
    <a class="btn btn-primary zh-only" href="#quickstart">快速开始</a>
    <a class="btn btn-primary en-only" href="#quickstart">Quick Start</a>
    <a class="btn btn-outline" href="https://github.com/SagaSmithAI" target="_blank">GitHub ›</a>
  </div>
</section>

<!-- Features -->
<section class="sec-light">
  <div class="container">
    <h2 class="zh-only">核心能力</h2><h2 class="en-only">Core Capabilities</h2>
    <p class="sec-sub zh-only">完整的 AI 地下城主工具集</p>
    <p class="sec-sub en-only">A complete AI Dungeon Master toolkit</p>
    <div class="grid-3">
      {features.map((f,i) => <div class="f-card anim anim-{i+1}">
        <span class="icon">{f.icon}</span>
